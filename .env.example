# -----------------------------------------------------------------------------
# Legal TimeLock Network (LTN) - Environment Variables Configuration Template
# Copy this file to .env and configure the variables for local development.
# -----------------------------------------------------------------------------

# Database Configuration (PostgreSQL / Neon)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/timelock?schema=public"

# Backend Server Configuration
PORT=5001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
CLIENT_URL="http://localhost:3000"
PUBLIC_APP_URL="http://localhost:3000"

# JSON Web Token Secret (for backend API session authentication)
# Generate a secure string using `openssl rand -base64 32`
JWT_SECRET="your_jwt_secret_key_minimum_32_characters_long"

# IPFS Provider Credentials (Pinata API Keys & Gateway)
PINATA_API_KEY="your_pinata_api_key"
PINATA_SECRET="your_pinata_api_secret"
PINATA_JWT="your_pinata_jwt_token"
PINATA_GATEWAY="silver-acceptable-bandicoot-606.mypinata.cloud"

# Solana Blockchain Node & Authority Relayer Key
SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_RELAYER_PRIVATE_KEY="your_solana_wallet_private_key_array_or_base58"

# NVIDIA AI / Nemotron Integration
NVIDIA_API_KEY="your_nvidia_api_key"
NVIDIA_MODEL="nvidia/nemotron-3-nano-30b-a3b"

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret"

# n8n Automation Webhooks
N8N_DOCUMENT_ASSIGNED_WEBHOOK="https://your-n8n-instance.com/webhook/document-assigned"
N8N_DOCUMENT_VERIFIED_WEBHOOK="https://your-n8n-instance.com/webhook/document-verified"

# Frontend Configuration (Next.js)
NEXT_PUBLIC_API_URL="http://localhost:5001/v1"
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"
