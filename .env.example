# -----------------------------------------------------------------------------
# Legal TimeLock Network (LTN) - Environment Variables Configuration Template
# Copy this file to .env and configure the variables for local development.
# -----------------------------------------------------------------------------

# Database Configuration (PostgreSQL)
# Prisma uses this URL to connect to the database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/timelock?schema=public"

# JSON Web Token Secret (for backend API session authentication)
# Generate a secure string (e.g. using `openssl rand -base64 32`)
JWT_SECRET="your_jwt_secret_key_minimum_32_characters_long"

# IPFS Provider Credentials (Pinata API Keys)
# Used by Storage Service to upload and pin encrypted documents
PINATA_API_KEY="your_pinata_api_key"
PINATA_SECRET="your_pinata_api_secret"

# Solana Blockchain Node & Authority relayer key
# - For localnet dev: http://127.0.0.1:8899
# - For devnet dev: https://api.devnet.solana.com
SOLANA_RPC_URL="https://api.devnet.solana.com"

# The Relayer's private key in base58 (or secret key array representation)
# This account pays transaction fees on Solana and signs initialize_document actions
SOLANA_RELAYER_PRIVATE_KEY="your_solana_wallet_private_key_in_base58"

# Frontend Configuration
# Points Next.js pages to the Express backend API
NEXT_PUBLIC_API_URL="http://localhost:5000/v1"
PORT=5000

# Public App URL for production QR code verification
PUBLIC_APP_URL="http://localhost:3000"
