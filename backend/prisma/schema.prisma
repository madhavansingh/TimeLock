// Active connector configuration, capabilities, and operational governance
model ConnectorConfig {
  id                  String    @id @default(uuid()) @map("id")
  tenantId            String?   @map("tenant_id")
  name                String    @unique // e.g. LAND_REGISTRY, COURT_SYSTEM
