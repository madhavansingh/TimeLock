model ContinuousEvaluationLog {
  evaluationId     String   @id @default(uuid()) @map("evaluation_id")
  agentName        String   @map("agent_name")
  precision        Float
  recall           Float
  falsePositiveRate Float   @map("false_positive_rate")
  falseNegativeRate Float   @map("false_negative_rate")
  latencyMs        Int      @map("latency_ms")
  driftScore       Float    @map("drift_score")
  calibrationScore Float    @map("calibration_score")
  anomalyCount     Int      @default(0) @map("anomaly_count")
  timestamp        DateTime @default(now())

  @@index([agentName, timestamp])
  @@map("continuous_evaluation_logs")
}

model AiCostMetric {
  metricId         String   @id @default(uuid()) @map("metric_id")
  tenantId         String?  @map("tenant_id")
  agentName        String   @map("agent_name")
  documentId       String?  @map("document_id")
  promptTokens     Int      @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  inferenceTimeMs  Int      @map("inference_time_ms")
  gpuUtilization   Float    @map("gpu_utilization")
  estimatedCost    Float    @map("estimated_cost")
  timestamp        DateTime @default(now())

  tenant           Tenant?  @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@index([tenantId, agentName])
  @@map("ai_cost_metrics")
}

model ExecutiveBriefing {
  briefingId       String   @id @default(uuid()) @map("briefing_id")
  tenantId         String?  @map("tenant_id")
  scope            String
  briefingContent  Json     @map("briefing_content")
  generatedBy      String   @map("generated_by")
  timestamp        DateTime @default(now())

  tenant           Tenant?  @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@map("executive_briefings")
}

model FeedbackLearningDataset {
  feedbackId       String   @id @default(uuid()) @map("feedback_id")
  tenantId         String?  @map("tenant_id")
  sourceType       String   @map("source_type")
  sourceId         String   @map("source_id")
  features         Json     @map("features")
  label            Json     @map("label")
  notes            String?  @map("notes")
  createdAt        DateTime @default(now()) @map("created_at")

  tenant           Tenant?  @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@index([sourceType])
  @@map("feedback_learning_datasets")
}

model SimulationResult {
  simulationId     String   @id @default(uuid()) @map("simulation_id")
  tenantId         String?  @map("tenant_id")
  name             String
  scenarios        Json
  impactReport     Json     @map("impact_report")
  runBy            String   @map("run_by")
  createdAt        DateTime @default(now()) @map("created_at")

  tenant           Tenant?  @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@map("simulation_results")
}

model IntelligenceInsight {
  insightId          String   @id @default(uuid()) @map("insight_id")
  tenantId           String?  @map("tenant_id")
  type               String
  targetId           String?  @map("target_id")
  prediction         Json
  recommendedActions String[] @map("recommended_actions")
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant           Tenant?  @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("intelligence_insights")
}



