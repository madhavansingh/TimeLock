// Upgraded Transactional Outbox supporting prioritization, expiry, and ordering
model OutboxEvent {
  id             String    @id @default(uuid()) @map("id")
  eventType      String    @map("event_type")
  eventVersion   Int       @default(1) @map("event_version")
  payload        Json      // Always in Canonical format
  correlationId  String?   @map("correlation_id")
  traceId        String?   @map("trace_id")
  status         String    @default("PENDING") // PENDING, PROCESSED, POISON, EXPIRED, FAILED
  attempts       Int       @default(0)
  priority       Int       @default(0)
  sequenceNumber Int       @default(0) @map("sequence_number")
  expiresAt      DateTime? @map("expires_at")
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")
  processedAt    DateTime? @map("processed_at")

  @@index([status, createdAt])
  @@index([correlationId])
  @@map("outbox_events")
}

// Cryptographically audited external interaction log with request provenance
model IntegrationAudit {
  id                  String   @id @default(uuid()) @map("id")
  connectorName       String   @map("connector_name")
  endpoint            String
  correlationId       String?  @map("correlation_id")
  traceId             String?  @map("trace_id")
  payloadHash         String   @map("payload_hash")
  responseHash        String   @map("response_hash")
