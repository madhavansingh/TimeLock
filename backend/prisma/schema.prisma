  retryCount          Int      @map("retry_count")
  result              String   @map("result") // SUCCESS, FAILED
  errorReason         String?  @map("error_reason")
  provenance          Json?    // Stores signatures, nonce, and timestamp validations
  timestamp           DateTime @default(now()) @map("timestamp")
  operatorId          String?  @map("operator_id")

  @@index([connectorName, timestamp])
  @@index([correlationId])
  @@map("integration_audits")
}

