# -----------------------------------------------------------------------------
# Legal TimeLock Network (LTN) - Backend Environment Variables Template
# Copy this file to backend/.env for local development.
# -----------------------------------------------------------------------------

# Database Configuration (PostgreSQL / Neon)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/timelock?schema=public"

# Server Settings
PORT=5001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
CLIENT_URL="http://localhost:3000"
PUBLIC_APP_URL="http://localhost:3000"

# Security & Authentication
JWT_SECRET="your_jwt_secret_key_minimum_32_characters_long"

# Pinata IPFS Integration
PINATA_API_KEY="your_pinata_api_key"
PINATA_SECRET="your_pinata_api_secret"
PINATA_JWT="your_pinata_jwt_token"
PINATA_GATEWAY="silver-acceptable-bandicoot-606.mypinata.cloud"

# Solana Blockchain Node & Authority Relayer Key
SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_RELAYER_PRIVATE_KEY="[your,solana,wallet,private,key,bytes]"

# NVIDIA AI / Nemotron Integration
NVIDIA_API_KEY="your_nvidia_api_key"
NVIDIA_MODEL="nvidia/nemotron-3-nano-30b-a3b"

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret"

# n8n Automation Webhooks
N8N_DOCUMENT_ASSIGNED_WEBHOOK="https://your-n8n-instance.com/webhook/document-assigned"
N8N_DOCUMENT_VERIFIED_WEBHOOK="https://your-n8n-instance.com/webhook/document-verified"
